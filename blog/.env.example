# Supabase Configuration (Required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin password for blog admin panel (change in production!)
VITE_ADMIN_PASSWORD_HASH=

# Base path for the blog (used for routing)
VITE_BASE_PATH=/blog

# Public site URL (used for canonical URLs, OG tags, JSON-LD)
VITE_SITE_URL=

# Google Analytics 4 Measurement ID (blog-specific property)
VITE_GA_MEASUREMENT_ID=
